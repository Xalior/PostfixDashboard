# --- Database --------------------------------------------------------------
# Either DATABASE_URL or the DB_* triplet below. DATABASE_URL wins if both set.
DATABASE_URL=mysql://postfix:postfix@localhost:3306/postfix
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=postfix
# DB_PASSWORD=postfix
# DB_NAME=postfix

# --- Session ---------------------------------------------------------------
# 32+ byte random string. Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-change-me-change-me-change-me-change-me
SESSION_COOKIE_NAME=postfix_dashboard_session
# How long a session lasts (seconds). Default 8h.
SESSION_MAX_AGE=28800

# --- Password hashing ------------------------------------------------------
# Default hash scheme for NEW accounts. Dovecot understands BLF-CRYPT natively.
# Supported: BLF-CRYPT (bcrypt), PLAIN
# Verification also supports: SHA512-CRYPT, MD5-CRYPT, CRYPT, PLAIN
PASSWORD_SCHEME=BLF-CRYPT
BCRYPT_ROUNDS=12

# --- Mailbox defaults ------------------------------------------------------
# Mailbox path template. Tokens: {domain}, {user}, {local}
MAILDIR_TEMPLATE=/virtual/{domain}/{user}/
# Default per-mailbox quota in MB (0 = unlimited)
DEFAULT_MAILBOX_QUOTA_MB=1024
# Default per-domain limits for new domains
DEFAULT_DOMAIN_MAILBOXES=100
DEFAULT_DOMAIN_ALIASES=100
DEFAULT_DOMAIN_QUOTA_MB=10240

# --- Features ---------------------------------------------------------------
FEATURE_VACATION=true
FEATURE_FETCHMAIL=false
FEATURE_DKIM=false
# Autoreply domain, used when vacation is enabled. See phppostfixadmin docs.
VACATION_DOMAIN=autoreply.example.com

# --- Branding ---------------------------------------------------------------
BRAND_NAME=Postfix Dashboard
DEFAULT_THEME=system

# --- Initial superadmin (only used by `npm run db:seed`) ------------------
SEED_SUPERADMIN_USERNAME=admin@example.com
SEED_SUPERADMIN_PASSWORD=ChangeMe123!
